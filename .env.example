# DeepSeek Brain - Environment Configuration
# Copy this file to .env and fill in your values

# Required: DeepSeek API Key
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-api-key-here

# Optional: Model selection
DEEPSEEK_MODEL=deepseek-reasoner

# Optional: API timeout (seconds)
DEEPSEEK_TIMEOUT=120

# Optional: Maximum reasoning loops
DEEPSEEK_MAX_LOOPS=10

# Optional: History file location
DEEPSEEK_HISTORY_FILE=/tmp/deepseek-qwen-history.json

# Optional: Enable verbose output
DEEPSEEK_VERBOSE=false

# Optional: YOLO mode (auto-execute commands)
DEEPSEEK_YOLO_MODE=true
